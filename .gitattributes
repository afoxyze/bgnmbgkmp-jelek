# Large generated datasets — tracked with Git LFS so the main repo stays small.
# To enable locally:
#   git lfs install
#   git lfs fetch --all
#
# Files listed here are committed today as plain blobs to keep the repo usable
# without LFS. Enable LFS before the next refresh to stop bloating .git history.

frontend/public/data/all_sppg_locations.json filter=lfs diff=lfs merge=lfs -text
frontend/public/data/sppg_points.json         filter=lfs diff=lfs merge=lfs -text
frontend/public/exports/pbp_id_sppg_data.json filter=lfs diff=lfs merge=lfs -text
frontend/public/exports/pbp_id_sppg_data.csv  filter=lfs diff=lfs merge=lfs -text

# Force LF on text files so diffs stay clean across platforms.
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
